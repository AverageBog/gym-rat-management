# Reference template for ./scripts/deploy-cloud-run.sh env vars.
#
# This .example file is checked in. The real values live at
# .env/cloud-run-vars (gitignored). To set up:
#
#   mkdir -p .env
#   cp .env.cloud-run.example .env/cloud-run-vars
#   # edit .env/cloud-run-vars with your real GCP_PROJECT and RUNTIME_SA
#   ./scripts/deploy-cloud-run.sh   # auto-sources .env/cloud-run-vars

# Required.
GCP_PROJECT=your-gcp-project-id

# Optional. Defaults shown.
GCP_REGION=us-central1
AR_REPO=gym-rat-management
SERVICE_NAME=gym-rat-management
RUNTIME_SA=the-service-account@your-gcp-project-id.iam.gserviceaccount.com

# Set to 1 to skip the local docker pre-flight (emergency redeploys only).
# DEPLOY_SKIP_LOCAL_TESTS=1
